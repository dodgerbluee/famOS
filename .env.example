# SandersHome Configuration

# AI Provider
AI_PROVIDER=ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Frigate
FRIGATE_URL=http://frigate.local:5000
MQTT_BROKER=tcp://mqtt.local:1883
MQTT_HOST=mqtt.local
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_DISCOVERY_PREFIX=homeassistant
MQTT_BASE_TOPIC=frigate
MQTT_CLIENT_ID=sandershome

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# Weather (get coordinates from Google Maps)
LOCATION_LAT=
LOCATION_LON=

# Auth
SESSION_SECRET=generate-a-random-string-here

# App display timezone (IANA name)
TZ=UTC
